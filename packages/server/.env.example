# Server-Konfiguration (lokal). Kopieren nach `.env` und Werte setzen.

# PostgreSQL (Docker Compose, siehe docker-compose.yml im Repo-Root).
# Host-Port 5433 (vermeidet Konflikt mit lokal installierter Postgres auf 5432).
DATABASE_URL=postgresql://schiffe:schiffe@localhost:5433/schiffe?schema=public

# Geheimnisse (zufällige, lange Werte verwenden)
COOKIE_SECRET=change-me-cookie-secret
GUEST_TOKEN_SECRET=change-me-guest-secret

# Netzwerk
PORT=3001
WEB_ORIGIN=http://localhost:3000

# Cookie-Sicherheit: in Produktion auf "true" setzen (HTTPS erforderlich)
COOKIE_SECURE=false

# Redis (Docker Compose, Host-Port 6380 vermeidet Konflikt mit lokalem Redis auf 6379).
# M3 (004): aktiver Lobby-/Spielzustand, Presence, Pub/Sub-Backplane (Socket.IO-Adapter).
REDIS_URL=redis://localhost:6380

# Zug-Timer & minimales Anti-Abuse (M3, 004). Bei fehlenden Werten greifen die Defaults.
TURN_TIMER_DEFAULT_SECONDS=30
MAX_OPEN_LOBBIES_PER_USER=5
JOIN_RATE_LIMIT_WINDOW_SECONDS=60
JOIN_RATE_LIMIT_MAX_FAILS=10

# Reconnect-Fenster in ms (M4, 005): reservierter Sitz nach Verbindungsabbruch. Spec fixiert 60 s.
RECONNECT_WINDOW_MS=60000

# Quick-Play-Wartetimeout in ms (M5, 006, FR-016): allein Wartende werden danach aus der Queue entfernt.
MATCHMAKING_TIMEOUT_MS=120000
